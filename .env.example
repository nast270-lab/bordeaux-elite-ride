# ========================================
# Bordeaux Privilège — Configuration locale
# ========================================
# Copier en .env (jamais commit). En prod : variables sur Render/Railway.

PORT=5000

# --- Twilio ---
# https://console.twilio.com → Dashboard → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# --- WhatsApp Business via Twilio ---
# Sandbox (dev) : whatsapp:+14155238886
# Production : votre numéro WhatsApp Business approuvé par Meta
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Numéro du gérant qui reçoit les notifications ---
# Format E.164 (sans préfixe whatsapp:)
MANAGER_PHONE=+33644691032

# --- URL publique du site ---
# Utilisée dans les messages WhatsApp automatiques (lien réservation, etc.)
SITE_URL=http://localhost:5000
