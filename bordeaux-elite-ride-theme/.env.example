# =============================================================================
# Bordeaux Elite Ride — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS committer le fichier .env dans git
# =============================================================================

# ─── API Anthropic (Claude) ──────────────────────────────────────────────────
# Créez votre clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# ─── Email du gérant (notifications de réservation et contact) ───────────────
BER_OWNER_EMAIL=votre@email.fr

# ─── Configuration WordPress ──────────────────────────────────────────────────
# Ces variables sont ajoutées dans wp-config.php (pas dans .env)
# Exemple de configuration dans wp-config.php :
#
# define('ANTHROPIC_API_KEY', getenv('ANTHROPIC_API_KEY') ?: 'sk-ant-...');
# define('BER_OWNER_EMAIL', getenv('BER_OWNER_EMAIL') ?: 'admin@votredomaine.fr');
#
# Pour la sécurité maximale, utilisez les variables d'environnement du serveur
# (ex: dans Apache : SetEnv ANTHROPIC_API_KEY sk-ant-...)
# (ex: dans Nginx + php-fpm : fastcgi_param ANTHROPIC_API_KEY sk-ant-...)

# ─── SMTP (optionnel — pour emails fiables) ───────────────────────────────────
# Si vous utilisez WP Mail SMTP ou similaire :
SMTP_HOST=smtp.votredomaine.fr
SMTP_PORT=587
SMTP_USER=noreply@votredomaine.fr
SMTP_PASS=votre_mot_de_passe_smtp
SMTP_FROM_NAME=Bordeaux Privilège
SMTP_FROM_EMAIL=noreply@votredomaine.fr

# ─── Coordonnées (référence — configurer dans le Customizer WordPress) ────────
# Ces valeurs sont gérées via Apparence > Personnaliser > Bordeaux Elite Ride
PHONE=+33644691032
PHONE_DISPLAY=+33 6 44 69 10 32
WHATSAPP=33644691032
EMAIL=contact@bordeaux-privilege.fr
BRAND_NAME=Bordeaux Privilège
