# ========================================
# VARIABLES D'ENVIRONNEMENT — DÉVELOPPEMENT LOCAL
# ========================================
# Copier ce fichier en .dev.vars (sans .example) puis remplir les valeurs.
# .dev.vars est ignoré par git (ne JAMAIS commiter).
#
# En production : variables configurées dans Cloudflare Pages
# Pages → bordeaux-elite-ride → Settings → Environment variables

# --- Twilio ---
# Récupérables sur https://console.twilio.com (Dashboard → Account Info)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Expéditeur alphanumérique (max 11 caractères, pas d'espaces)
TWILIO_SENDER_ID=BdxPrivil

# --- Numéros de téléphone ---
# Format E.164 obligatoire : +336XXXXXXXX ou +337XXXXXXXX
OWNER_PHONE_NUMBER=+33644691032
