# ========================================
# VARIABLES D'ENVIRONNEMENT — DÉVELOPPEMENT LOCAL
# ========================================
# Copier ce fichier en .dev.vars (sans .example) puis remplir les valeurs.
# .dev.vars est ignoré par git (ne JAMAIS commiter).
#
# En production : variables configurées dans Cloudflare Pages
# Pages → bordeaux-elite-ride → Settings → Environment variables

# --- Twilio (SMS fallback) ---
# Récupérables sur https://console.twilio.com (Dashboard → Account Info)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Expéditeur alphanumérique SMS (max 11 caractères, sans espaces)
# Utilisé uniquement si TWILIO_WHATSAPP_NUMBER n'est pas défini
TWILIO_SENDER_ID=BdxPrivil

# --- WhatsApp Business via Twilio ---
# Sandbox (développement) : whatsapp:+14155238886
# Production : votre numéro WhatsApp Business approuvé par Meta
# Si cette variable est définie, les notifications sont envoyées via WhatsApp.
# Laissez vide pour utiliser SMS à la place.
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- URL du site ---
# Incluse dans les messages WhatsApp automatiques du chatbot
SITE_URL=https://bordeaux-elite-ride.pages.dev

# --- Numéros de téléphone ---
# Format E.164 obligatoire : +336XXXXXXXX ou +337XXXXXXXX
OWNER_PHONE_NUMBER=+33644691032
